library(randomForest)
varImpPlot(
rf_model,
main = "Random Forest Feature Importance",
col = "#C2185B"
)
library(randomForest)
set.seed(123)
rf_model <- randomForest(
log_price ~ room_type +
neighbourhood +
minimum_nights +
number_of_reviews +
reviews_per_month +
availability_365 +
calculated_host_listings_count,
data = train,
ntree = 300
)
